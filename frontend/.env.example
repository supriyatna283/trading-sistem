# Backend API (required)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Must match backend API_KEY when set (required for writes in production)
NEXT_PUBLIC_API_KEY=

# WebSocket base (optional — defaults from API URL)
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8000

# Telegram proxy (Vercel only — if deploying frontend to Vercel)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PROXY_SECRET=
